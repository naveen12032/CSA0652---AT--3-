#include <stdio.h>
struct Job {
    int id, profit, deadline;
};
int main() {
    struct Job jobs[] = {
        {1,100,2},
        {2,19,1},
        {3,27,2},
        {4,25,1},
        {5,15,3}
    };
    int slot[4]={0};
    int profit=0;
    for(int i=0;i<5;i++) {
        for(int j=i+1;j<5;j++) {
            if(jobs[i].profit < jobs[j].profit) {
                struct Job temp=jobs[i];
                jobs[i]=jobs[j];
                jobs[j]=temp;
            }
        }
    }

    for(int i=0;i<5;i++) {
        for(int j=jobs[i].deadline;j>0;j--) {
            if(slot[j]==0) {
                slot[j]=jobs[i].id;
                profit+=jobs[i].profit;
                break;
            }
        }
    }

    printf("Maximum Profit = %d\n",profit);

    int weights[]={10,20,30,40};
    int capacity=60,sum=0;

    printf("Loaded Containers: ");

    for(int i=0;i<4;i++) {
        if(sum+weights[i]<=capacity) {
            sum+=weights[i];
            printf("%d ",weights[i]);
        }
    }

    printf("\nTotal Loaded Weight = %d",sum);

    return 0;
}
